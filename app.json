{
  "expo": {
    "name": "FamilyCart",
    "slug": "rn-homestock",
    "version": "1.0.0",
    "scheme": "familycart",
    "icon": "./assets/images/online-shopping.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "userInterfaceStyle": "light"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F8FAF9",
        "foregroundImage": "./assets/images/online-shopping.png"
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F8FAF9",
          "dark": {
            "backgroundColor": "#F8FAF9"
          }
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
